{
    "$schema": "https://railway.app/railway.schema.json",
    "services": {
        "openclaw-predictor-frontend": {
            "build": {
                "builder": "DOCKERFILE",
                "dockerfilePath": "frontend/Dockerfile",
                "rootDirectory": "frontend"
            },
            "deploy": {
                "healthcheckPath": "/",
                "restartPolicyType": "ON_FAILURE"
            }
        },
        "openclaw-predictor-agent": {
            "build": {
                "builder": "DOCKERFILE",
                "dockerfilePath": "rector/Dockerfile"
            }
        }
    }
}