# Agent wallet — pays ALL gas
# Users never need a wallet
PRIVATE_KEY=0x...

# OpenClaw
OPENCLAW_TELEGRAM_TOKEN=your_telegram_bot_token
OPENCLAW_GATEWAY_PORT=18789

# Contract (fill after deployment)
PREDICTION_REGISTRY_ADDRESS=0x...

# AI
OPENAI_API_KEY=sk-...

# Market Data
BINANCE_API_URL=https://api.binance.com
BINANCE_WS_URL=wss://stream.binance.com:9443

# Infrastructure
DATABASE_URL=postgresql://user:password@localhost:5432/openclaw_predictor
REDIS_URL=redis://localhost:6379

# BNB Greenfield
GREENFIELD_RUNBOOKS_BUCKET=predict-runbooks
GREENFIELD_EVIDENCE_BUCKET=predict-evidence

# BSCScan (for contract verification)
BSCSCAN_API_KEY=your_bscscan_api_key

# Frontend (read only — prefix with NEXT_PUBLIC_)
NEXT_PUBLIC_REGISTRY_ADDRESS=0x...
NEXT_PUBLIC_BSC_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/
NEXT_PUBLIC_BSCSCAN_URL=https://testnet.bscscan.com
