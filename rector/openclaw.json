{
    "mcpServers": {
        "bnbchain-mcp": {
            "command": "npx",
            "args": [
                "-y",
                "@bnb-chain/mcp@latest"
            ],
            "env": {
                "PRIVATE_KEY": "${PRIVATE_KEY}"
            }
        }
    },
    "channels": {
        "telegram": {
            "botToken": "${TELEGRAM_BOT_TOKEN}",
            "dmPolicy": "open"
        }
    },
    "gateway": {
        "auth": {
            "token": "${OPENCLAW_GATEWAY_TOKEN}"
        }
    }
}