{
    "channels": {
        "telegram": {
            "botToken": "${TELEGRAM_BOT_TOKEN}",
            "dmPolicy": "open",
            "allowFrom": [
                "*"
            ]
        }
    },
    "gateway": {
        "auth": {
            "token": "${OPENCLAW_GATEWAY_TOKEN}"
        }
    },
    "plugins": {
        "entries": {
            "mcp-adapter": {
                "enabled": true,
                "config": {
                    "servers": [
                        {
                            "name": "binance",
                            "transport": "stdio",
                            "command": "npx",
                            "args": [
                                "-y",
                                "@snjyor/binance-mcp@latest"
                            ]
                        },
                        {
                            "name": "bnb-chain",
                            "transport": "stdio",
                            "command": "npx",
                            "args": [
                                "-y",
                                "@bnb-chain/mcp"
                            ]
                        }
                    ]
                }
            }
        }
    }
}