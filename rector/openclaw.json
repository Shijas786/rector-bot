{
    "mcpServers": {
        "bnbchain-mcp": {
            "command": "npx",
            "args": [
                "-y",
                "@bnb-chain/mcp@latest"
            ],
            "env": {
                "PRIVATE_KEY": "${PRIVATE_KEY}"
            }
        }
    },
    "channels": {
        "telegram": {
            "token": "${OPENCLAW_TELEGRAM_TOKEN}",
            "allowFrom": [
                "*"
            ]
        }
    }
}